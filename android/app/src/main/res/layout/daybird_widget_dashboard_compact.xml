<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboard_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_dashboard_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="종합 대시보드" android:textColor="#17181C" android:textSize="21sp" android:textStyle="bold" />
    <TextView android:id="@+id/dashboard_date" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="오늘 상태 요약" android:textColor="#7B7E87" android:textSize="10sp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="76dp" android:layout_marginTop="6dp" android:background="@drawable/widget_dashboard_card" android:orientation="vertical" android:padding="9dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="bottom" android:orientation="horizontal"><TextView android:id="@+id/dashboard_score" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#141518" android:textSize="30sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="2dp" android:layout_marginBottom="5dp" android:text="점" android:textColor="#24252A" android:textSize="11sp" android:textStyle="bold" /></LinearLayout>
            <TextView android:id="@+id/dashboard_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/widget_dashboard_pill" android:ellipsize="end" android:maxWidth="135dp" android:maxLines="1" android:paddingLeft="9dp" android:paddingTop="6dp" android:paddingRight="9dp" android:paddingBottom="6dp" android:text="데이터 연결 대기" android:textColor="#1687F7" android:textSize="10sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
            <TextView android:id="@+id/dashboard_domain_food" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—/100" android:textColor="#F2A21B" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_domain_health" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—/100" android:textColor="#24AD62" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_domain_running" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—/100" android:textColor="#348CF7" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_domain_spending" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—/100" android:textColor="#8D61E8" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_domain_wine" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—/100" android:textColor="#DE4960" android:textSize="9sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="96dp" android:layout_marginTop="6dp" android:orientation="horizontal">
        <LinearLayout android:id="@+id/dashboard_food_card" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/widget_dashboard_card" android:orientation="vertical" android:padding="9dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="음식" android:textColor="#222329" android:textSize="11sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal"><TextView android:id="@+id/dashboard_food_percent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#25262A" android:textSize="20sp" android:textStyle="bold" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="7dp" android:layout_weight="1" android:orientation="vertical"><TextView android:id="@+id/dashboard_food_calories" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="연결 대기" android:textColor="#34363D" android:textSize="9sp" android:textStyle="bold" /><TextView android:id="@+id/dashboard_food_macro" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="식단 데이터 필요" android:textColor="#7B7E87" android:textSize="8sp" /></LinearLayout></LinearLayout>
            <ProgressBar android:id="@+id/dashboard_food_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:indeterminate="false" android:max="100" android:progress="0" android:progressDrawable="@drawable/widget_dashboard_progress" />
        </LinearLayout>
        <LinearLayout android:id="@+id/dashboard_health_card" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/widget_dashboard_card" android:orientation="vertical" android:padding="9dp">
            <TextView android:id="@+id/dashboard_health_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="헬스 목표" android:textColor="#222329" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_workout_one" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:text="연결 대기" android:textColor="#45474F" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_workout_two" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#45474F" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_workout_three" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#45474F" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_workout_four" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#45474F" android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="154dp" android:layout_marginTop="6dp" android:orientation="horizontal">
        <LinearLayout android:id="@+id/dashboard_running_card" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/widget_dashboard_card" android:orientation="vertical" android:padding="9dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="러닝 최근 5회" android:textColor="#222329" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_running_record_1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:text="러닝 데이터 필요" android:textColor="#3F424A" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_running_record_2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#3F424A" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_running_record_3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#3F424A" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_running_record_4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#3F424A" android:textSize="8sp" />
            <TextView android:id="@+id/dashboard_running_record_5" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:ellipsize="end" android:maxLines="1" android:textColor="#3F424A" android:textSize="8sp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/dashboard_spending_card" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/widget_dashboard_card" android:orientation="vertical" android:padding="9dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="소비 추이" android:textColor="#222329" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/dashboard_spending_two_week" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:ellipsize="end" android:maxLines="1" android:text="2주 소비 데이터 필요" android:textColor="#41434B" android:textSize="9sp" android:textStyle="bold" />
            <ProgressBar android:id="@+id/dashboard_spending_two_week_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp" android:indeterminate="false" android:max="1" android:progress="0" android:progressDrawable="@drawable/widget_dashboard_progress" />
            <TextView android:id="@+id/dashboard_spending_today" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:ellipsize="end" android:maxLines="1" android:text="오늘 소비 데이터 필요" android:textColor="#41434B" android:textSize="9sp" android:textStyle="bold" />
            <ProgressBar android:id="@+id/dashboard_spending_today_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp" android:indeterminate="false" android:max="1" android:progress="0" android:progressDrawable="@drawable/widget_dashboard_progress" />
            <TextView android:id="@+id/dashboard_point_info" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom" android:ellipsize="end" android:maxLines="2" android:text="가계부 포인트를 설정해 주세요" android:textColor="#7650B9" android:textSize="8sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/dashboard_wine_card" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="6dp" android:background="@drawable/widget_dashboard_card" android:orientation="horizontal" android:padding="8dp">
        <ImageView android:id="@+id/dashboard_wine_image" android:layout_width="42dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:contentDescription="최근 와인 썸네일" android:scaleType="centerCrop" android:visibility="gone" />
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical"><TextView android:id="@+id/dashboard_wine_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="와인 데이터 필요" android:textColor="#222329" android:textSize="11sp" android:textStyle="bold" /><LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom" android:orientation="horizontal"><TextView android:id="@+id/dashboard_wine_note" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:text="테이스팅 노트 필요" android:textColor="#747780" android:textSize="8sp" /><TextView android:id="@+id/dashboard_wine_rating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— / 5.0" android:textColor="#B88412" android:textSize="9sp" android:textStyle="bold" /></LinearLayout></LinearLayout>
    </LinearLayout>
</LinearLayout>
