<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/agenda_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:contentDescription="@string/app_name" android:src="@mipmap/ic_launcher" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="9dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/agenda_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7월 13일 월" android:textColor="#1C1C1E" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:id="@+id/agenda_summary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오늘의 다음 일정" android:textColor="#73737B" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/agenda_row_1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="8dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/agenda_color_1" android:layout_width="4dp" android:layout_height="match_parent" android:background="#5AA9F8" />
        <TextView android:id="@+id/agenda_time_1" android:layout_width="48dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="09:00" android:textColor="#73737B" android:textSize="11sp" />
        <TextView android:id="@+id/agenda_title_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="다이소 쇼핑&#10;• 비닐봉지  • 입욕제" android:textColor="#1C1C1E" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:id="@+id/agenda_row_2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="4dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/agenda_color_2" android:layout_width="4dp" android:layout_height="match_parent" android:background="#45C88A" />
        <TextView android:id="@+id/agenda_time_2" android:layout_width="48dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="12:00" android:textColor="#73737B" android:textSize="11sp" />
        <TextView android:id="@+id/agenda_title_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="팀 점심" android:textColor="#1C1C1E" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:id="@+id/agenda_row_3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="4dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/agenda_color_3" android:layout_width="4dp" android:layout_height="match_parent" android:background="#FFB340" />
        <TextView android:id="@+id/agenda_time_3" android:layout_width="48dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="14:10" android:textColor="#73737B" android:textSize="11sp" />
        <TextView android:id="@+id/agenda_title_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="팀 브레인스토밍" android:textColor="#1C1C1E" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:id="@+id/agenda_row_4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="4dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/agenda_color_4" android:layout_width="4dp" android:layout_height="match_parent" android:background="#AF52DE" />
        <TextView android:id="@+id/agenda_time_4" android:layout_width="48dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="18:00" android:textColor="#73737B" android:textSize="11sp" />
        <TextView android:id="@+id/agenda_title_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="운동" android:textColor="#1C1C1E" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>

    <TextView android:id="@+id/agenda_empty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="8dp" android:layout_weight="3" android:gravity="center" android:text="오늘 남은 일정이 없어요" android:textColor="#73737B" android:textSize="12sp" android:visibility="gone" />
</LinearLayout>
