{
  "name": "daybird",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5500",
    "assets": "node scripts/generate-assets.mjs",
    "build": "npm run assets && tsc -b && vite build",
    "build:android": "npm run assets && tsc -b && vite build --mode android",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "cap:sync": "npm run build:android && cap sync android",
    "android:debug": "node scripts/build-android.mjs debug",
    "android:release": "node scripts/build-android.mjs release",
    "signing:setup": "node scripts/setup-signing.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "@fontsource/pretendard": "^5.2.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@capacitor/cli": "^8.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "sharp": "^0.33.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
